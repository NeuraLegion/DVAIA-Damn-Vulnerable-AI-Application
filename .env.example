# DVAIA - Environment Configuration Example
# Copy this file to .env and customize as needed

# ============================================================
# Application Configuration (with defaults)
# ============================================================

# Flask server port (default: 5000)
#PORT=5000

# Default LLM model (default: gpt-4o-mini)
#DEFAULT_MODEL=gpt-4o-mini

# Agentic panel model for CoT/reasoning (default: gpt-4o-mini)
#AGENTIC_MODEL=gpt-4o-mini

# ============================================================
# OpenAI API Key (REQUIRED)
# ============================================================

# OpenAI API key — set this to your key
OPENAI_API_KEY=your-openai-api-key-here

# Embedding model for RAG (default: text-embedding-3-small)
#EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# Security (REQUIRED for production)
# ============================================================

# Flask secret key for sessions
# Generate with: openssl rand -hex 32
#SECRET_KEY=your-secret-key-here

# ============================================================
# Storage Paths (Docker uses /tmp by default)
# ============================================================

# Database path (default: data/app.db, Docker: /tmp/app.db)
#DATABASE_URI=/tmp/app.db

# Uploaded files directory (default: data/uploads, Docker: /tmp/uploads)
#UPLOAD_DIR=/tmp/uploads

# Payload generation output (default: data/payloads, Docker: /tmp/payloads/generate)
#PAYLOADS_OUTPUT_DIR=/tmp/payloads/generate

# ============================================================
# Qdrant Vector Database (for RAG features)
# ============================================================

# Qdrant URL (default: http://localhost:6333)
# Docker Compose automatically sets QDRANT_HOST=qdrant
#QDRANT_URL=http://localhost:6333

# Qdrant collection name (default: rag_chunks)
#QDRANT_COLLECTION=rag_chunks

# Qdrant API key (optional, for Qdrant Cloud)
#QDRANT_API_KEY=

# ============================================================
# Notes
# ============================================================
#
# - Most values have sensible defaults in core/config.py
# - Only uncomment and set values you want to override
# - Docker Compose sets QDRANT_HOST automatically
# - Keep secrets (SECRET_KEY, OPENAI_API_KEY) in .env, not in version control
# - See README.md for full documentation
